<mvc:View controllerName="repository.secret.ui.controller.App"
    xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout">
    <App id="app">
    <Page title="CI/CD Credentials Subsystem">
        <IconTabBar id="idIconTabBar" expanded="true">
            <items>
                <!-- tab 1: SECRETS -->
                <IconTabFilter icon="sap-icon://key" text="Secrets" key="secrets">
                  <Panel headerText="Add New Secret" class="sapUiSmallMarginBottom">
                                    <l:HorizontalLayout>
                                        <!-- Поле за Име -->
                                        <Input id="inpSecretName" placeholder="Secret Name (Identifier)" width="200px" class="sapUiSmallMarginEnd"/>
                                        
                                        <!-- НОВО: Падащо меню за Провайдър -->
                                        <Select id="selProviderType" forceSelection="true" width="150px" class="sapUiSmallMarginEnd">
                                            <core:Item key="" text="Select a provider" />
                                            <core:Item key="GITHUB" text="GitHub" />
                                        </Select>

                                        <!-- Поле за Парола/Токен -->
                                        <Input id="inpSecretValue" type="Password" placeholder="Token/Password" width="200px" class="sapUiSmallMarginEnd"/>
                                        
                                        <Button text="Add Secret" type="Emphasized" icon="sap-icon://add" press=".onAddSecret"/>
                                    </l:HorizontalLayout>
                                </Panel>
                                <Table items="{/secrets}" noDataText="No secrets found. Add your first secret.">
                                    <columns>
                                        <!--Column><Text text="ID" /></Column-->
                                        <Column><Text text="Secret Name" /></Column>
                                          <Column><Text text="Provider" /></Column>
                                        <Column hAlign="End"><Text text="Actions" /></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem>
                                            <cells>
                                                <!--Text text="{id}" /-->
                                                <ObjectIdentifier title="{name}" />
                                                 <Text text="{providerType}" /> 
                                                <Button icon="sap-icon://delete" type="Reject" press=".onDeleteSecret"/>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                </IconTabFilter>
                
                <!-- tab 2: REPOSITORIES -->
                <IconTabFilter icon="sap-icon://source-code" text="Repositories" key="repos">
                   <Panel headerText="Add New Repository" class="sapUiMarginBottom">
                                    <l:HorizontalLayout>
                                        <Input id="inpRepoUrl" placeholder="https://github.com/my/repo.git" width="300px" class="sapUiSmallMarginEnd"/>
                                       
                                        <Select id="selSecret" forceSelection="false" width="200px" class="sapUiSmallMarginEnd" items="{/dropdownSecrets}">
                                            <items>
                                                <core:Item key="{id}" text="{name}" />
                                            </items>
                                        </Select>

                                        <Button text="Add Repo" type="Emphasized" icon="sap-icon://add" press=".onAddRepo"/>
                                    </l:HorizontalLayout>
                                </Panel>

                                <Table items="{/repos}" noDataText="No repositories linked yet. Use the form to add one.">
                                    <columns>
                                        <!--Column><Text text="ID" /></Column-->
                                        <Column><Text text="URL" /></Column>
                                        <Column><Text text="Linked Secret" /></Column>
                                        <Column hAlign="End"><Text text="Actions" /></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem>
                                    <cells>
                                        <Text text="{url}" />
                                        <Text text="{secretName}" />
                                        <HBox justifyContent="End">
                                            <Button text="Validate" icon="sap-icon://connected" press=".onValidateRepo" class="sapUiTinyMarginEnd"/>
                                            <Button icon="sap-icon://edit" type="Attention" press=".onEditRepo" tooltip="Edit" class="sapUiTinyMarginEnd" />
                                            <Button icon="sap-icon://delete" type="Reject" press=".onDeleteRepo"/>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                                    </items>
                                </Table>
                </IconTabFilter>
            </items>
        </IconTabBar>
    </Page>
    </App>
</mvc:View>